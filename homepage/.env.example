# Portainer API Key
# Generate at: Portainer > My Account > Access Tokens > Add access token
HOMEPAGE_VAR_PORTAINER_KEY=

# Portainer Environment ID
# Find at: Portainer > Environments > click your environment > check the URL for the ID number
HOMEPAGE_VAR_PORTAINER_ENV=2

# AdGuard Home credentials (same as your AdGuard login)
HOMEPAGE_VAR_ADGUARD_USER=
HOMEPAGE_VAR_ADGUARD_PASS=
